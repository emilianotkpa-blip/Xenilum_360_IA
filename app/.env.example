# Copia este archivo a `.env` y rellena los valores.
# ⚠️ Las variables VITE_* se hornean en el bundle JS PÚBLICO al hacer `npm run build`.
#    No pongas aquí llaves privadas (OpenAI, service_role, VAPID privada, etc.).

# Base de los endpoints Xenilum en n8n
VITE_API_BASE=https://prueba-n8n-prueba.urdzg3.easypanel.host/webhook/api

# Acceso server-to-server a los endpoints (temporal, hasta tener login Supabase).
# Valor real en backend/docs/SECRETS.local.md
VITE_XEN_KEY=xen_TU_LLAVE_AQUI

# Usuario por defecto
VITE_USER_EMAIL=emilianotkpa@gmail.com

# Web Push: clave PÚBLICA VAPID (se puede exponer). Genera el par con:
#   npx web-push generate-vapid-keys
# La privada va SOLO en n8n. Deja vacío para desactivar el botón de avisos.
VITE_VAPID_PUBLIC_KEY=
